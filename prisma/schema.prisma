generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                   String                @id @default(cuid())
  category             String
  name                 String
  brand                String
  flavor               String?
  imageUrl             String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  offers               Offer[]
  creatineInfo         CreatineInfo?
  wheyInfo             WheyInfo?
  proteinBarInfo       ProteinBarInfo?
  proteinDrinkInfo     ProteinDrinkInfo?
  functionalCoffeeInfo FunctionalCoffeeInfo?
  preWorkoutInfo       PreWorkoutInfo?
}

model CreatineInfo {
  id           String       @id @default(cuid())
  productId    String       @unique
  form         CreatineForm
  totalUnits   Float
  unitsPerDose Float
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([form])
}

model WheyInfo {
  id                    String  @id @default(cuid())
  productId             String  @unique
  totalWeightInGrams    Float
  doseInGrams           Float
  proteinPerDoseInGrams Float
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProteinBarInfo {
  id                    String  @id @default(cuid())
  productId             String  @unique
  doseInGrams           Float
  proteinPerDoseInGrams Float
  unitsPerBox           Int
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProteinDrinkInfo {
  id                    String  @id @default(cuid())
  productId             String  @unique
  unitsPerPack          Int
  volumePerUnitInMl     Float
  proteinPerUnitInGrams Float
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model FunctionalCoffeeInfo {
  id                  String  @id @default(cuid())
  productId           String  @unique
  product             Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  totalWeightInGrams  Float
  doseInGrams         Float
  caffeinePerDoseInMg Float
}

model PreWorkoutInfo {
  id                  String  @id @default(cuid())
  productId           String  @unique
  totalWeightInGrams  Float
  doseInGrams         Float
  caffeinePerDoseInMg Float
  product             Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Offer {
  id            String              @id @default(cuid())
  productId     String
  store         Store
  externalId    String
  seller        String?
  price         Float
  affiliateUrl  String
  createdAt     DateTime            @default(now())
  ratingAverage Float?
  ratingCount   Int?
  updatedAt     DateTime            @updatedAt
  product       Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceHistory  OfferPriceHistory[]

  @@unique([store, externalId])
  @@index([productId])
  @@index([store])
}

model OfferPriceHistory {
  id        String   @id @default(cuid())
  offerId   String
  price     Float
  createdAt DateTime @default(now())
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId, createdAt])
}

model AmazonImportQueue {
  id        String   @id @default(cuid())
  asin      String   @unique
  createdAt DateTime @default(now())
}

enum Store {
  AMAZON
  MERCADO_LIVRE
}

enum CreatineForm {
  POWDER
  CAPSULE
  GUMMY
}

model DynamicCategory {
  id            String           @id @default(cuid())
  group         String           @default("casa")
  groupName     String           @default("Casa e Limpeza")
  name          String
  slug          String
  imageUrl      String?
  displayConfig Json
  products      DynamicProduct[]
  asinDecisions DynamicCategoryAsinDecision[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([group, slug])
}

model DynamicProduct {
  id               String                @id @default(cuid())
  asin             String                @unique
  name             String
  totalPrice       Float
  isVisibleOnSite  Boolean               @default(true)
  visibilityStatus String                @default("visible")
  lastValidPrice   Float?
  lastValidPriceAt DateTime?
  availabilityStatus String?            @default("UNKNOWN")
  lastAvailabilityCheckedAt DateTime?
  averagePrice30d  Float?
  lowestPrice30d   Float?
  highestPrice30d  Float?
  lowestPrice365d  Float?
  priceStatsUpdatedAt DateTime?
  url              String
  imageUrl         String?
  categoryId       String
  category         DynamicCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attributes       Json
  ratingAverage    Float?
  ratingCount      Int?
  ratingsUpdatedAt DateTime?
  priceHistory     DynamicPriceHistory[]
  clickStats       DynamicProductClickStats?
  clickEvents      DynamicProductClickEvent[]
  issueReports     DynamicProductIssueReport[]
  reactions        DynamicProductReaction[]
  favorites        SiteUserFavorite[]
  comments         SiteProductComment[]
  listItems        SiteUserListItem[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model DynamicCategoryAsinDecision {
  id            String          @id @default(cuid())
  categoryId    String
  category      DynamicCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  asin          String
  status        String
  reasonCode    String?
  reasonText    String?
  policyHash    String?
  title         String?
  brand         String?
  imageUrl      String?
  observedPrice Float?
  productId     String?
  firstSeenAt   DateTime        @default(now())
  lastSeenAt    DateTime        @default(now())
  reviewedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([categoryId, asin])
  @@index([categoryId, status, lastSeenAt(sort: Desc)])
  @@index([asin])
  @@index([status, lastSeenAt(sort: Desc)])
}

model DynamicProductIssueReport {
  id        String         @id @default(cuid())
  productId String
  product   DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  asin      String
  reason    String
  details   String?
  pagePath  String?
  status    String         @default("open")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([productId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model DynamicProductReaction {
  id        String         @id @default(cuid())
  productId String
  product   DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  visitorId String
  reaction  String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([productId, visitorId])
  @@index([productId, reaction])
  @@index([createdAt(sort: Desc)])
}

model DynamicSiteConfig {
  key                      String   @id
  fallbackEnabled          Boolean  @default(false)
  fallbackManualEnabled    Boolean  @default(false)
  fallbackAutoEnabled      Boolean  @default(true)
  fallbackAutoFailedProductsThreshold Int @default(20)
  fallbackSource           String?
  fallbackMaxAgeHours      Int      @default(24)
  fallbackReason           String?
  fallbackActivatedAt      DateTime?
  clickEmailAlertsEnabled  Boolean  @default(false)
  clickAlertEmailTo        String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model GlobalPriceRefreshRun {
  id               String   @id @default(cuid())
  status           String
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
  totalOffers      Int      @default(0)
  updatedOffers    Int      @default(0)
  failedOffers     Int      @default(0)
  maxConsecutiveFailedOffers Int @default(0)
  outOfStockOffers Int      @default(0)
  excludedOffers   Int      @default(0)
  errorMessage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([startedAt(sort: Desc)])
}

model DynamicPriceHistory {
  id          String         @id @default(cuid())
  productId   String
  product     DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  price       Float
  updateCount Int            @default(1)
  date        DateTime
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([productId, date])
  @@index([productId, date])
}

model DynamicProductClickStats {
  id            String         @id @default(cuid())
  productId     String         @unique
  product       DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  clickCount    Int            @default(0)
  lastClickedAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model DynamicProductClickEvent {
  id             String         @id @default(cuid())
  productId      String
  product        DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  visitorId      String?
  sessionId      String?
  session        DynamicClickSession? @relation(fields: [sessionId], references: [sessionId], onDelete: SetNull)
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  inferredSource String?
  pagePath       String?
  referrer       String?
  createdAt      DateTime       @default(now())

  @@index([sessionId, createdAt(sort: Desc)])
  @@index([productId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model DynamicClickSession {
  id                String                    @id @default(cuid())
  visitorId         String
  sessionId         String                    @unique
  source            String?
  firstPagePath     String?
  startedAt         DateTime
  lastActivityAt    DateTime
  endedAt           DateTime?
  summaryEmailSentAt DateTime?
  totalClicks       Int                       @default(0)
  uniqueProducts    Int                       @default(0)
  clickEvents       DynamicProductClickEvent[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([visitorId, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
  @@index([endedAt])
}

model PriorityRefreshRun {
  id                String   @id @default(cuid())
  source            String   @default("sqs_priority")
  status            String
  startedAt         DateTime @default(now())
  finishedAt        DateTime?
  processedMessages Int      @default(0)
  uniqueAsins       Int      @default(0)
  updatedProducts   Int      @default(0)
  skippedProducts   Int      @default(0)
  errorMessage      String?
  updatedAsins      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([startedAt(sort: Desc)])
}

model DynamicImportRun {
  id                  String   @id @default(cuid())
  status              String
  categoryId          String
  totalItems          Int      @default(0)
  processedItems      Int      @default(0)
  importedItems       Int      @default(0)
  skippedItems        Int      @default(0)
  errorItems          Int      @default(0)
  cancelRequested     Boolean  @default(false)
  filters             Json?
  logs                Json?
  startedAt           DateTime @default(now())
  finishedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
}

model DynamicDiscoveryRun {
  id                  String   @id @default(cuid())
  status              String
  totalSearches       Int      @default(0)
  processedSearches   Int      @default(0)
  foundItems          Int      @default(0)
  cancelRequested     Boolean  @default(false)
  inputs              Json?
  items               Json?
  logs                Json?
  startedAt           DateTime @default(now())
  finishedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
}

model SiteUser {
  id                String                  @id @default(cuid())
  email             String                  @unique
  passwordHash      String
  displayName       String
  avatarUrl         String?
  bio               String?
  role              String                  @default("user")
  googleId          String?                 @unique
  emailVerifiedAt   DateTime?
  emailVerificationTokenHash String?
  emailVerificationExpiresAt DateTime?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  lastLoginAt       DateTime?
  sessions          SiteSession[]
  favorites         SiteUserFavorite[]
  comments          SiteProductComment[]
  commentReactions  SiteProductCommentReaction[]
  lists             SiteUserList[]
  productSuggestions SiteProductSuggestion[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([createdAt(sort: Desc)])
}

model SiteSession {
  id         String   @id @default(cuid())
  userId     String
  user       SiteUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model SiteUserFavorite {
  id         String         @id @default(cuid())
  userId     String
  user       SiteUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  product    DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  note       String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([userId, productId])
  @@index([productId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model SiteProductComment {
  id         String               @id @default(cuid())
  productId  String
  product    DynamicProduct       @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String
  user       SiteUser             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     SiteProductComment?  @relation("SiteCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    SiteProductComment[] @relation("SiteCommentReplies")
  reactions  SiteProductCommentReaction[]
  body       String
  status     String               @default("published")
  isEdited   Boolean              @default(false)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([productId, createdAt(sort: Desc)])
  @@index([parentId, createdAt(sort: Asc)])
  @@index([userId, createdAt(sort: Desc)])
}

model SiteProductCommentReaction {
  id         String             @id @default(cuid())
  commentId   String
  comment     SiteProductComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId      String
  user        SiteUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reaction    String             @default("like")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([commentId, userId, reaction])
  @@index([commentId, reaction])
  @@index([userId, createdAt(sort: Desc)])
}

model SiteUserList {
  id          String            @id @default(cuid())
  userId      String
  user        SiteUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String            @unique
  title       String
  description String?
  isPublic    Boolean           @default(false)
  items       SiteUserListItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([isPublic, updatedAt(sort: Desc)])
}

model SiteUserListItem {
  id         String         @id @default(cuid())
  listId      String
  list        SiteUserList   @relation(fields: [listId], references: [id], onDelete: Cascade)
  productId   String
  product     DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  note        String?
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([listId, productId])
  @@index([productId])
  @@index([listId, sortOrder, createdAt(sort: Desc)])
}

model SiteProductSuggestion {
  id           String    @id @default(cuid())
  userId       String
  user         SiteUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asin         String?
  amazonUrl    String?
  title        String?
  notes        String?
  status       String    @default("pending")
  reviewNotes  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}
