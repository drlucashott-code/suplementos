generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                   String                @id @default(cuid())
  category             String
  name                 String
  brand                String
  flavor               String?
  imageUrl             String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  offers               Offer[]
  creatineInfo         CreatineInfo?
  wheyInfo             WheyInfo?
  proteinBarInfo       ProteinBarInfo?
  proteinDrinkInfo     ProteinDrinkInfo?
  functionalCoffeeInfo FunctionalCoffeeInfo?
  preWorkoutInfo       PreWorkoutInfo?
}

model CreatineInfo {
  id           String       @id @default(cuid())
  productId    String       @unique
  form         CreatineForm
  totalUnits   Float
  unitsPerDose Float
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([form])
}

model WheyInfo {
  id                    String  @id @default(cuid())
  productId             String  @unique
  totalWeightInGrams    Float
  doseInGrams           Float
  proteinPerDoseInGrams Float
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProteinBarInfo {
  id                    String  @id @default(cuid())
  productId             String  @unique
  doseInGrams           Float
  proteinPerDoseInGrams Float
  unitsPerBox           Int
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProteinDrinkInfo {
  id                    String  @id @default(cuid())
  productId             String  @unique
  unitsPerPack          Int
  volumePerUnitInMl     Float
  proteinPerUnitInGrams Float
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model FunctionalCoffeeInfo {
  id                  String  @id @default(cuid())
  productId           String  @unique
  product             Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  totalWeightInGrams  Float
  doseInGrams         Float
  caffeinePerDoseInMg Float
}

model PreWorkoutInfo {
  id                  String  @id @default(cuid())
  productId           String  @unique
  totalWeightInGrams  Float
  doseInGrams         Float
  caffeinePerDoseInMg Float
  product             Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Offer {
  id            String              @id @default(cuid())
  productId     String
  store         Store
  externalId    String
  seller        String?
  price         Float
  affiliateUrl  String
  createdAt     DateTime            @default(now())
  ratingAverage Float?
  ratingCount   Int?
  updatedAt     DateTime            @updatedAt
  product       Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceHistory  OfferPriceHistory[]

  @@unique([store, externalId])
  @@index([productId])
  @@index([store])
}

model OfferPriceHistory {
  id        String   @id @default(cuid())
  offerId   String
  price     Float
  createdAt DateTime @default(now())
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId, createdAt])
}

model AmazonImportQueue {
  id        String   @id @default(cuid())
  asin      String   @unique
  createdAt DateTime @default(now())
}

enum Store {
  AMAZON
  MERCADO_LIVRE
}

enum CreatineForm {
  POWDER
  CAPSULE
  GUMMY
}

model DynamicCategory {
  id            String           @id @default(cuid())
  group         String           @default("casa")
  groupName     String           @default("Casa e Limpeza")
  name          String
  slug          String
  imageUrl      String?
  displayConfig Json
  products      DynamicProduct[]
  asinDecisions DynamicCategoryAsinDecision[]
  discoveryConfig DynamicDiscoveryCategoryConfig?
  discoveryBrands DynamicDiscoveryBrandStatus[]
  discoveryProducts DynamicDiscoveryProductStatus[]
  discoveryRuns DynamicDiscoveryRun[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([group, slug])
}

model DynamicProduct {
  id               String                @id @default(cuid())
  asin             String                @unique
  name             String
  totalPrice       Float
  isVisibleOnSite  Boolean               @default(true)
  visibilityStatus String                @default("visible")
  lastValidPrice   Float?
  lastValidPriceAt DateTime?
  availabilityStatus String?            @default("UNKNOWN")
  lastAvailabilityCheckedAt DateTime?
  averagePrice30d  Float?
  lowestPrice30d   Float?
  highestPrice30d  Float?
  lowestPrice365d  Float?
  priceStatsUpdatedAt DateTime?
  refreshTier      String                @default("cold")
  priorityScore    Float                 @default(0)
  lastPrioritySignalAt DateTime?
  lastInteractionAt DateTime?
  lastRefreshAttemptAt DateTime?
  lastPriceRefreshAt DateTime?
  lastSuccessfulRefreshAt DateTime?
  nextPriceRefreshAt DateTime?
  nextPriorityEnqueueAt DateTime?
  refreshFailCount Int                   @default(0)
  priceChangeFrequency Float             @default(0)
  dataFreshnessScore Float               @default(0)
  refreshLockUntil DateTime?
  url              String
  imageUrl         String?
  categoryId       String
  category         DynamicCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attributes       Json
  ratingAverage    Float?
  ratingCount      Int?
  ratingsUpdatedAt DateTime?
  priceHistory     DynamicPriceHistory[]
  clickStats       DynamicProductClickStats?
  clickEvents      DynamicProductClickEvent[]
  issueReports     DynamicProductIssueReport[]
  reactions        DynamicProductReaction[]
  favorites        SiteUserFavorite[]
  comments         SiteProductComment[]
  listItems        SiteUserListItem[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model DynamicCategoryAsinDecision {
  id            String          @id @default(cuid())
  categoryId    String
  category      DynamicCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  asin          String
  sourceAsin    String?
  status        String
  reasonCode    String?
  reasonText    String?
  policyHash    String?
  title         String?
  brand         String?
  imageUrl      String?
  observedPrice Float?
  productId     String?
  firstSeenAt   DateTime        @default(now())
  lastSeenAt    DateTime        @default(now())
  reviewedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([categoryId, asin])
  @@index([categoryId, status, lastSeenAt(sort: Desc)])
  @@index([asin])
  @@index([status, lastSeenAt(sort: Desc)])
}

model DynamicDiscoveryCategoryConfig {
  id                    String   @id @default(cuid())
  categoryId            String   @unique
  category              DynamicCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  mode                  String   @default("individual")
  primeOnlyDefault      Boolean  @default(false)
  freeDeliveryDefault   Boolean  @default(false)
  ignoreInternationalDefault Boolean @default(true)
  multiBrandDefault     Boolean  @default(true)
  broadDiscoveryDefault Boolean  @default(false)
  defaultSortBy         String   @default("featured")
  autoMaxPages          Boolean  @default(true)
  maxPages              Int      @default(2)
  autoMaxItemsPerQuery  Boolean  @default(true)
  maxItemsPerQuery      Int      @default(30)
  searchTerms           String[] @default([])
  seedBrands            String[] @default([])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model DynamicDiscoveryBrandStatus {
  id             String         @id @default(cuid())
  categoryId     String
  category       DynamicCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  brandName      String
  status         String         @default("pending")
  relevanceScore Float          @default(0)
  timesDetected  Int            @default(0)
  firstSeenAt    DateTime       @default(now())
  lastSeenAt     DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([categoryId, brandName])
  @@index([categoryId, status, relevanceScore(sort: Desc)])
  @@index([categoryId, lastSeenAt(sort: Desc)])
}

model DynamicDiscoveryProductStatus {
  id              String         @id @default(cuid())
  categoryId      String
  category        DynamicCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  asin            String
  title           String?
  status          String         @default("pending")
  catalogState    String         @default("new")
  reason          String?
  source          String         @default("relevance")
  query           String
  brandName       String?
  ratingAverage   Float?
  reviewCount     Int?
  searchPosition  Int?
  sponsored       Boolean        @default(false)
  isPrime         Boolean        @default(false)
  isInternational Boolean        @default(false)
  timesDetected   Int            @default(1)
  relevanceScore  Float          @default(0)
  queriesDetected String[]       @default([])
  sources         String[]       @default([])
  firstSeenAt     DateTime       @default(now())
  lastSeenAt      DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([categoryId, asin])
  @@index([categoryId, status, relevanceScore(sort: Desc)])
  @@index([categoryId, catalogState, lastSeenAt(sort: Desc)])
  @@index([asin])
}

model DynamicDiscoveryRun {
  id                 String         @id @default(cuid())
  categoryId         String
  category           DynamicCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  mode               String
  primeOnly          Boolean        @default(false)
  freeDelivery       Boolean        @default(false)
  ignoreInternational Boolean        @default(true)
  multiBrand         Boolean        @default(true)
  broadDiscovery     Boolean        @default(false)
  sortBy             String[]
  searchTerms        String[]
  seedBrands         String[]
  status             String         @default("done")
  queryCount         Int            @default(0)
  asinCount          Int            @default(0)
  newCount           Int            @default(0)
  existingCount      Int            @default(0)
  pendingCount       Int            @default(0)
  rejectedCount      Int            @default(0)
  approvedCount      Int            @default(0)
  exportAsins        String[]       @default([])
  previewSummary     Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([categoryId, createdAt(sort: Desc)])
  @@index([categoryId, status, createdAt(sort: Desc)])
  @@map("DynamicDiscoveryExecution")
}

model LegacyDynamicDiscoveryRun {
  id                  String   @id @default(cuid())
  status              String
  totalSearches       Int      @default(0)
  processedSearches   Int      @default(0)
  foundItems          Int      @default(0)
  cancelRequested     Boolean  @default(false)
  inputs              Json?
  items               Json?
  logs                Json?
  startedAt           DateTime @default(now())
  finishedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
  @@map("DynamicDiscoveryRun")
}

model DynamicProductIssueReport {
  id        String         @id @default(cuid())
  productId String
  product   DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  asin      String
  reason    String
  details   String?
  pagePath  String?
  status    String         @default("open")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([productId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model DynamicProductReaction {
  id        String         @id @default(cuid())
  productId String
  product   DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  visitorId String
  reaction  String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([productId, visitorId])
  @@index([productId, reaction])
  @@index([createdAt(sort: Desc)])
}

model DynamicSiteConfig {
  key                      String   @id
  fallbackEnabled          Boolean  @default(false)
  fallbackManualEnabled    Boolean  @default(false)
  fallbackAutoEnabled      Boolean  @default(true)
  fallbackAutoFailedProductsThreshold Int @default(20)
  fallbackSource           String?
  fallbackMaxAgeHours      Int      @default(24)
  fallbackReason           String?
  fallbackActivatedAt      DateTime?
  clickEmailAlertsEnabled  Boolean  @default(false)
  clickAlertEmailTo        String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model GlobalPriceRefreshRun {
  id               String   @id @default(cuid())
  status           String
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
  totalOffers      Int      @default(0)
  updatedOffers    Int      @default(0)
  failedOffers     Int      @default(0)
  maxConsecutiveFailedOffers Int @default(0)
  outOfStockOffers Int      @default(0)
  excludedOffers   Int      @default(0)
  errorMessage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([startedAt(sort: Desc)])
}

model DynamicPriceHistory {
  id          String         @id @default(cuid())
  productId   String
  product     DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  price       Float
  updateCount Int            @default(1)
  date        DateTime
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([productId, date])
  @@index([productId, date])
}

model DynamicProductClickStats {
  id            String         @id @default(cuid())
  productId     String         @unique
  product       DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  clickCount    Int            @default(0)
  lastClickedAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model DynamicProductClickEvent {
  id             String         @id @default(cuid())
  productId      String
  product        DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  visitorId      String?
  sessionId      String?
  session        DynamicClickSession? @relation(fields: [sessionId], references: [sessionId], onDelete: SetNull)
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  inferredSource String?
  pagePath       String?
  referrer       String?
  createdAt      DateTime       @default(now())

  @@index([sessionId, createdAt(sort: Desc)])
  @@index([productId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model DynamicClickSession {
  id                String                    @id @default(cuid())
  visitorId         String
  sessionId         String                    @unique
  source            String?
  firstPagePath     String?
  startedAt         DateTime
  lastActivityAt    DateTime
  endedAt           DateTime?
  summaryEmailSentAt DateTime?
  totalClicks       Int                       @default(0)
  uniqueProducts    Int                       @default(0)
  clickEvents       DynamicProductClickEvent[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([visitorId, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
  @@index([endedAt])
}

model PriorityRefreshRun {
  id                String   @id @default(cuid())
  source            String   @default("sqs_priority")
  status            String
  startedAt         DateTime @default(now())
  finishedAt        DateTime?
  processedMessages Int      @default(0)
  uniqueAsins       Int      @default(0)
  updatedProducts   Int      @default(0)
  skippedProducts   Int      @default(0)
  errorMessage      String?
  updatedAsins      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([startedAt(sort: Desc)])
}

model DynamicImportRun {
  id                  String   @id @default(cuid())
  status              String
  categoryId          String
  totalItems          Int      @default(0)
  processedItems      Int      @default(0)
  importedItems       Int      @default(0)
  skippedItems        Int      @default(0)
  errorItems          Int      @default(0)
  cancelRequested     Boolean  @default(false)
  filters             Json?
  logs                Json?
  startedAt           DateTime @default(now())
  finishedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
}

model SiteUser {
  id                String                  @id @default(cuid())
  email             String                  @unique
  passwordHash      String
  displayName       String
  username          String?                 @unique
  avatarUrl         String?
  bio               String?
  role              String                  @default("user")
  commentsBlocked   Boolean                 @default(false)
  googleId          String?                 @unique
  emailVerifiedAt   DateTime?
  emailVerificationTokenHash String?
  emailVerificationExpiresAt DateTime?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  lastLoginAt       DateTime?
  sessions          SiteSession[]
  favorites         SiteUserFavorite[]
  monitoredProducts SiteUserMonitoredProduct[]
  comments          SiteProductComment[]
  commentReactions  SiteProductCommentReaction[]
  listComments      SiteUserListComment[]
  listCommentReactions SiteUserListCommentReaction[]
  lists             SiteUserList[]
  savedLists        SiteUserSavedList[]
  notifications     SiteUserNotification[]
  notificationPreference SiteUserNotificationPreference?
  pushSubscriptions SiteUserPushSubscription[]
  notificationDeliveries SiteNotificationDelivery[]
  productSuggestions SiteProductSuggestion[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([createdAt(sort: Desc)])
}

model SiteSession {
  id         String   @id @default(cuid())
  userId     String
  user       SiteUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model SiteUserFavorite {
  id         String         @id @default(cuid())
  userId     String
  user       SiteUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  product    DynamicProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  note       String?
  sortOrder  Int            @default(0)
  lastTrackedPrice Float?
  lastTrackedAvailability String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([userId, productId])
  @@index([productId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model SiteUserMonitoredProduct {
  id                    String    @id @default(cuid())
  userId                String
  user                  SiteUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackedProductId      String?
  trackedProduct        SiteTrackedAmazonProduct? @relation(fields: [trackedProductId], references: [id], onDelete: SetNull)
  listItems             SiteUserListItem[]
  asin                  String
  amazonUrl             String
  name                  String
  imageUrl              String?
  totalPrice            Float     @default(0)
  averagePrice30d       Float?
  availabilityStatus    String?   @default("UNKNOWN")
  programAndSavePrice   Float?
  sortOrder             Int       @default(0)
  lastTrackedPrice      Float?
  lastTrackedAvailability String?
  lastSyncedAt          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([userId, asin])
  @@unique([userId, trackedProductId])
  @@index([asin])
  @@index([trackedProductId])
  @@index([userId, createdAt(sort: Desc)])
}

model SiteTrackedAmazonProduct {
  id                    String    @id @default(cuid())
  asin                  String    @unique
  amazonUrl             String
  name                  String
  imageUrl              String?
  ratingAverage         Float?
  ratingCount           Int?
  ratingsUpdatedAt      DateTime?
  totalPrice            Float     @default(0)
  averagePrice30d       Float?
  lowestPrice30d        Float?
  highestPrice30d       Float?
  lowestPrice365d       Float?
  availabilityStatus    String?   @default("UNKNOWN")
  programAndSavePrice   Float?
  lastSyncedAt          DateTime?
  refreshTier           String    @default("cold")
  priorityScore         Float     @default(0)
  lastPrioritySignalAt  DateTime?
  lastInteractionAt     DateTime?
  lastRefreshAttemptAt  DateTime?
  lastPriceRefreshAt    DateTime?
  lastSuccessfulRefreshAt DateTime?
  nextPriceRefreshAt    DateTime?
  nextPriorityEnqueueAt DateTime?
  refreshFailCount      Int       @default(0)
  priceChangeFrequency  Float     @default(0)
  dataFreshnessScore    Float     @default(0)
  refreshLockUntil      DateTime?
  monitorCount          Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  monitoredBy           SiteUserMonitoredProduct[]
  listItems             SiteUserListItem[]
  priceHistory          SiteTrackedAmazonProductPriceHistory[]

  @@index([createdAt(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
}

model SiteTrackedAmazonProductPriceHistory {
  id               String                   @id @default(cuid())
  trackedProductId String
  trackedProduct   SiteTrackedAmazonProduct @relation(fields: [trackedProductId], references: [id], onDelete: Cascade)
  price            Float
  updateCount      Int                      @default(1)
  date             DateTime
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([trackedProductId, date])
  @@index([trackedProductId, date])
}

model SiteProductComment {
  id         String               @id @default(cuid())
  productId  String
  product    DynamicProduct       @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String
  user       SiteUser             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     SiteProductComment?  @relation("SiteCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    SiteProductComment[] @relation("SiteCommentReplies")
  reactions  SiteProductCommentReaction[]
  body       String
  status     String               @default("published")
  isEdited   Boolean              @default(false)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([productId, createdAt(sort: Desc)])
  @@index([parentId, createdAt(sort: Asc)])
  @@index([userId, createdAt(sort: Desc)])
}

model SiteProductCommentReaction {
  id         String             @id @default(cuid())
  commentId   String
  comment     SiteProductComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId      String
  user        SiteUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reaction    String             @default("like")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([commentId, userId, reaction])
  @@index([commentId, reaction])
  @@index([userId, createdAt(sort: Desc)])
}

model SiteUserListComment {
  id         String                @id @default(cuid())
  listId      String
  list        SiteUserList          @relation(fields: [listId], references: [id], onDelete: Cascade)
  userId      String
  user        SiteUser              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      SiteUserListComment?  @relation("SiteListCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     SiteUserListComment[] @relation("SiteListCommentReplies")
  reactions   SiteUserListCommentReaction[]
  body        String
  status      String                @default("published")
  isEdited    Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([listId, createdAt(sort: Desc)])
  @@index([parentId, createdAt(sort: Asc)])
  @@index([userId, createdAt(sort: Desc)])
}

model SiteUserListCommentReaction {
  id         String              @id @default(cuid())
  commentId   String
  comment     SiteUserListComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId      String
  user        SiteUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reaction    String             @default("like")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([commentId, userId, reaction])
  @@index([commentId, reaction])
  @@index([userId, createdAt(sort: Desc)])
}

model SiteUserList {
  id          String            @id @default(cuid())
  userId      String
  user        SiteUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String            @unique
  title       String
  description String?
  isPublic    Boolean           @default(false)
  isDefault   Boolean           @default(false)
  items       SiteUserListItem[]
  comments    SiteUserListComment[]
  savedBy     SiteUserSavedList[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([isPublic, updatedAt(sort: Desc)])
  @@index([userId, isDefault])
}

model SiteUserListItem {
  id         String         @id @default(cuid())
  listId      String
  list        SiteUserList   @relation(fields: [listId], references: [id], onDelete: Cascade)
  productId   String?
  product     DynamicProduct? @relation(fields: [productId], references: [id], onDelete: Cascade)
  monitoredProductId String?
  monitoredProduct   SiteUserMonitoredProduct? @relation(fields: [monitoredProductId], references: [id], onDelete: Cascade)
  trackedAmazonProductId String?
  trackedAmazonProduct   SiteTrackedAmazonProduct? @relation(fields: [trackedAmazonProductId], references: [id], onDelete: Cascade)
  note        String?
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
 
  @@unique([listId, productId])
  @@unique([listId, monitoredProductId])
  @@unique([listId, trackedAmazonProductId])
  @@index([productId])
  @@index([monitoredProductId])
  @@index([trackedAmazonProductId])
  @@index([listId, sortOrder, createdAt(sort: Desc)])
}

model SiteUserSavedList {
  id         String       @id @default(cuid())
  userId     String
  user       SiteUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listId     String
  list       SiteUserList @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([userId, listId])
  @@index([listId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model SiteUserNotification {
  id         String    @id @default(cuid())
  userId     String
  user       SiteUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   String    @default("social")
  type       String
  title      String
  body       String?
  href       String?
  metadata   Json?
  priority   Int       @default(0)
  groupedKey String?
  actorUserId String?
  targetUserId String?
  targetProductId String?
  targetListId String?
  targetCommentId String?
  deliveries SiteNotificationDelivery[]
  isRead     Boolean   @default(false)
  readAt     DateTime?
  clickedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, category, createdAt(sort: Desc)])
  @@index([userId, groupedKey])
  @@index([targetProductId])
  @@index([targetListId])
  @@index([targetCommentId])
  @@index([targetUserId])
  @@index([actorUserId])
}

model SiteUserNotificationPreference {
  userId                String   @id
  user                  SiteUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentRepliesCentralEnabled Boolean  @default(true)
  commentRepliesPushEnabled Boolean  @default(false)
  commentRepliesEmailEnabled Boolean  @default(false)
  commentReactionsCentralEnabled Boolean  @default(true)
  commentReactionsPushEnabled Boolean  @default(false)
  commentReactionsEmailEnabled Boolean  @default(false)
  listCommentsCentralEnabled Boolean  @default(true)
  listCommentsPushEnabled Boolean  @default(false)
  listCommentsEmailEnabled Boolean  @default(false)
  listFollowsCentralEnabled Boolean  @default(true)
  listFollowsPushEnabled Boolean  @default(false)
  listFollowsEmailEnabled Boolean  @default(false)
  mentionsCentralEnabled Boolean  @default(true)
  mentionsPushEnabled Boolean  @default(false)
  mentionsEmailEnabled Boolean  @default(false)
  priceDropsCentralEnabled Boolean  @default(true)
  priceDropsPushEnabled Boolean  @default(false)
  priceDropsEmailEnabled Boolean  @default(false)
  backInStockCentralEnabled Boolean  @default(true)
  backInStockPushEnabled Boolean  @default(false)
  backInStockEmailEnabled Boolean  @default(false)
  commentsEnabled       Boolean  @default(true)
  mentionsEnabled       Boolean  @default(true)
  reactionsEnabled      Boolean  @default(true)
  followersEnabled      Boolean  @default(true)
  priceDropEnabled      Boolean  @default(true)
  stockReturnEnabled    Boolean  @default(true)
  centralEnabled        Boolean  @default(true)
  pushEnabled           Boolean  @default(false)
  emailEnabled          Boolean  @default(false)
  priceAlertMode        String   @default("any")
  priceAlertPercentage  Int      @default(10)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SiteUserPushSubscription {
  id          String   @id @default(cuid())
  userId      String
  user        SiteUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint    String   @unique
  p256dh      String
  auth        String
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  revokedAt   DateTime?

  @@index([userId, createdAt(sort: Desc)])
}

model SiteNotificationDelivery {
  id              String   @id @default(cuid())
  notificationId   String?
  notification     SiteUserNotification? @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId          String
  user            SiteUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel         String
  status          String   @default("pending")
  providerMessageId String?
  scheduledAt     DateTime @default(now())
  sentAt          DateTime?
  attemptCount    Int      @default(0)
  lastError       String?
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, scheduledAt])
  @@index([userId, channel, status])
  @@index([notificationId])
}

model SiteProductSuggestion {
  id           String    @id @default(cuid())
  userId       String
  user         SiteUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asin         String?
  amazonUrl    String?
  title        String?
  notes        String?
  status       String    @default("pending")
  reviewNotes  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model PriceRefreshBudgetWindow {
  id            String   @id @default(cuid())
  scope         String
  windowType    String
  windowStart   DateTime
  windowEnd     DateTime
  requestCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([scope, windowType, windowStart])
  @@index([scope, windowType, windowStart(sort: Desc)])
}

model AdminSchedulerActionLog {
  id              String   @id @default(cuid())
  actor           String   @default("admin")
  actionType      String
  productSource   String
  asin            String
  productId       String?
  trackedProductId String?
  notes           String?
  createdAt       DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([actionType, createdAt(sort: Desc)])
  @@index([asin, createdAt(sort: Desc)])
}
